# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Chatbot Service (Python FastAPI)
CHATBOT_SERVICE_URL=http://localhost:8000

# AI Configuration
# OpenAI API (kept for backward compatibility)
OPENAI_API_KEY=your-openai-api-key-here
# Gemini API (kept for backward compatibility)
GEMINI_API_KEY=your-gemini-api-key-here
# OpenRouter API (Primary - used for Invoice and Prescription scanning with Gemini 2.0 Flash)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Logging
LOG_LEVEL=info
