# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Valkey/Redis Cache Configuration
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
CACHE_TTL=300

# Chatbot Service (Python FastAPI)
CHATBOT_SERVICE_URL=http://localhost:8000

# OpenAI Configuration (for Invoice & Prescription Image Recognition with GPT-4o)
OPENAI_API_KEY=your-openai-api-key-here

# Email Configuration - Resend (for low stock alerts)
RESEND_API_KEY=your-resend-api-key-here
ADMIN_EMAIL=admin@pharmacare.com

# SMTP Configuration (for supplier order emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_SECURE=false

# Google Custom Search API (optional - for public supplier search)
GOOGLE_SEARCH_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# Logging
LOG_LEVEL=info
