// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  PHARMACIST
  CASHIER
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING
  CANCELLED
  REFUNDED
}

enum ReorderStatus {
  PENDING
  APPROVED
  ORDERED
  RECEIVED
  REJECTED
}

// ==================== MODELS ====================

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(PHARMACIST)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  sales             Sale[]           @relation
  requestedReorders ReorderRequest[] @relation("RequestedReorders")
  approvedReorders  ReorderRequest[] @relation("ApprovedReorders")

  @@map("users")
}

model Drug {
  id                   String   @id @default(cuid())
  brandName            String   @map("brand_name")
  genericName          String   @map("generic_name")
  chemicalName         String?  @map("chemical_name")
  dosage               String?
  category             String
  manufacturer         String
  requiresPrescription Boolean  @default(false) @map("requires_prescription")
  reorderLevel         Int      @default(10) @map("reorder_level")
  sku                  String   @unique @default(cuid())
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  inventoryBatches InventoryBatch[]
  saleItems        SaleItem[]
  stockAlerts      StockAlert[]
  reorderRequests  ReorderRequest[]

  @@map("drugs")
}

model Supplier {
  id            String   @id @default(cuid())
  supplierName  String   @map("supplier_name")
  contactNumber String   @map("contact_number")
  email         String   @unique
  address       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  inventoryBatches InventoryBatch[]
  reorderRequests  ReorderRequest[]

  @@map("suppliers")
}

model InventoryBatch {
  id            String   @id @default(cuid())
  drugId        String   @map("drug_id")
  batchNumber   String   @map("batch_number")
  quantity      Int
  purchasePrice Decimal  @map("purchase_price") @db.Decimal(10, 2)
  sellPrice     Decimal  @map("sell_price") @db.Decimal(10, 2)
  expiryDate    DateTime @map("expiry_date")
  supplierId    String?  @map("supplier_id")
  location      String?
  dateAdded     DateTime @default(now()) @map("date_added")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  drug      Drug       @relation(fields: [drugId], references: [id], onDelete: Cascade)
  supplier  Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  saleItems SaleItem[]

  @@map("inventory_batches")
}

model Sale {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  customerId    String?       @map("customer_id")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  cashReceived  Decimal?      @map("cash_received") @db.Decimal(10, 2)
  changeGiven   Decimal?      @map("change_given") @db.Decimal(10, 2)
  transactionId String?       @map("transaction_id") // Razorpay payment ID
  saleDate      DateTime      @default(now()) @map("sale_date")
  status        SaleStatus    @default(COMPLETED)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer               Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  saleItems              SaleItem[]
  prescriptionHistories  PrescriptionHistory[]

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String  @map("sale_id")
  drugId    String  @map("drug_id")
  batchId   String  @map("batch_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  // Relations
  sale  Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  drug  Drug           @relation(fields: [drugId], references: [id], onDelete: Cascade)
  batch InventoryBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sales Sale[]

  @@map("customers")
}

model StockAlert {
  id        String   @id @default(cuid())
  drugId    String   @map("drug_id")
  alertType String   @map("alert_type") // LOW_STOCK, EXPIRING_SOON, EXPIRED
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  drug Drug @relation(fields: [drugId], references: [id], onDelete: Cascade)

  @@map("stock_alerts")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model ReorderRequest {
  id               String        @id @default(cuid())
  drugId           String        @map("drug_id")
  requestedBy      String        @map("requested_by") // User ID
  requestedQty     Int           @map("requested_qty")
  currentStock     Int           @default(0) @map("current_stock")
  reorderLevel     Int           @map("reorder_level")
  status           ReorderStatus @default(PENDING)
  priority         String        @default("MEDIUM") // HIGH, MEDIUM, LOW
  notes            String?
  approvedBy       String?       @map("approved_by") // User ID
  approvedAt       DateTime?     @map("approved_at")
  orderedAt        DateTime?     @map("ordered_at")
  receivedAt       DateTime?     @map("received_at")
  supplierId       String?       @map("supplier_id")
  estimatedCost    Decimal?      @map("estimated_cost") @db.Decimal(10, 2)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  drug           Drug      @relation(fields: [drugId], references: [id], onDelete: Cascade)
  requestedByUser User     @relation("RequestedReorders", fields: [requestedBy], references: [id], onDelete: Cascade)
  approvedByUser  User?    @relation("ApprovedReorders", fields: [approvedBy], references: [id], onDelete: SetNull)
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@map("reorder_requests")
}

model PrescriptionHistory {
  id                  String   @id @default(cuid())
  saleId              String   @map("sale_id")
  patientName         String   @map("patient_name")
  doctorName          String?  @map("doctor_name")
  prescriptionDate    DateTime? @map("prescription_date")
  medications         String   @db.Text // JSON array of medications
  totalAmount         Decimal  @map("total_amount") @db.Decimal(10, 2)
  paymentMethod       String   @map("payment_method")
  customerName        String   @map("customer_name")
  customerPhone       String?  @map("customer_phone")
  customerEmail       String?  @map("customer_email")
  customerAddress     String?  @map("customer_address")
  notes               String?
  confidence          Float?   @default(0.0) // AI scan confidence score
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("prescription_histories")
}
