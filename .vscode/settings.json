{
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": false
  },
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,
  "yaml.schemaStore.enable": true,
  "yaml.schemas": {
    "https://cdn.jsdelivr.net/gh/aws/cloudformation-coverage-roadmap@main/cfn-lint/CloudFormationLintRuleSet.json": [
      "cloudformation.yaml",
      "template.yaml",
      "*.template"
    ]
  },
  "yaml.customTags": [
    "!And",
    "!Base64",
    "!Cidr",
    "!Equals",
    "!FindInMap",
    "!GetAtt",
    "!GetAZs",
    "!If",
    "!ImportValue",
    "!Join",
    "!Not",
    "!Or",
    "!Ref",
    "!Select",
    "!Sub"
  ],
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": false
  },
  "redhat.telemetry.enabled": false
}
