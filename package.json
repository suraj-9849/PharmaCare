{
  "name": "PharmaCare",
  "version": "1.0.0",
  "private": true,
  "description": "PharmaCare - Professional Pharmacy Management System",
  "packages": [
    "ph_backend",
    "ph_frontend",
    "ai_assistant"
  ],
  "scripts": {
    "prepare": "[[ ! -d '.git' ]] || husky install || true",
    "validate": "node scripts/validate.js",
    "backend:dev": "cd ph_backend && bun dev",
    "backend:build": "cd ph_backend && bun build",
    "backend:type-check": "cd ph_backend && bun type-check",
    "backend:lint": "cd ph_backend && bun lint",
    "backend:lint:fix": "cd ph_backend && bun lint:fix",
    "backend:format": "cd ph_backend && bun format",
    "backend:format:check": "cd ph_backend && bun format:check",
    "frontend:dev": "cd ph_frontend && bun dev",
    "frontend:build": "cd ph_frontend && bun build",
    "frontend:type-check": "cd ph_frontend && bun type-check",
    "frontend:lint": "cd ph_frontend && bun lint",
    "frontend:lint:fix": "cd ph_frontend && bun lint:fix",
    "frontend:format": "cd ph_frontend && bun format",
    "frontend:format:check": "cd ph_frontend && bun format:check",
    "ai:setup": "cd ai_assistant && python -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install uv && .venv/bin/uv pip install -e '.[dev]' && .venv/bin/uv pip install uvicorn",
    "ai:dev": "cd ai_assistant && .venv/bin/uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "ai:lint": "cd ai_assistant && .venv/bin/flake8 .",
    "ai:format": "cd ai_assistant && .venv/bin/black .",
    "ai:format:check": "cd ai_assistant && .venv/bin/black --check .",
    "ai:type-check": "cd ai_assistant && .venv/bin/mypy . --ignore-missing-imports || true",
    "ai:test": "cd ai_assistant && .venv/bin/pytest -v",
    "dev": "concurrently \"bun backend:dev\" \"bun frontend:dev\"",
    "type-check": "bun backend:type-check && bun frontend:type-check && bun ai:type-check",
    "lint": "bun backend:lint && bun frontend:lint && bun ai:lint",
    "lint:fix": "bun backend:lint:fix && bun frontend:lint:fix",
    "format": "bun backend:format && bun frontend:format && bun ai:format",
    "format:check": "bun backend:format:check && bun frontend:format:check && bun ai:format:check",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "pharmacy",
    "healthcare",
    "management",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "baseline-browser-mapping": "^2.10.40",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7"
  },
  "workspaces": [
    "ph_backend",
    "ph_frontend"
  ]
}
