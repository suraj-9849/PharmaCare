{
  "name": "DrugDesk",
  "version": "1.0.0",
  "private": true,
  "description": "DrugDesk - Professional Pharmacy Management System",
  "packages": [
    "ph_backend",
    "ph_frontend"
  ],
  "scripts": {
    "prepare": "[[ ! -d '.git' ]] || husky install || true",
    "validate": "node scripts/validate.js",
    "backend:dev": "cd ph_backend && pnpm dev",
    "backend:build": "cd ph_backend && pnpm build",
    "backend:type-check": "cd ph_backend && pnpm type-check",
    "backend:lint": "cd ph_backend && pnpm lint",
    "backend:lint:fix": "cd ph_backend && pnpm lint:fix",
    "backend:format": "cd ph_backend && pnpm format",
    "backend:format:check": "cd ph_backend && pnpm format:check",
    "frontend:dev": "cd ph_frontend && pnpm dev",
    "frontend:build": "cd ph_frontend && pnpm build",
    "frontend:type-check": "cd ph_frontend && pnpm type-check",
    "frontend:lint": "cd ph_frontend && pnpm lint",
    "frontend:lint:fix": "cd ph_frontend && pnpm lint:fix",
    "frontend:format": "cd ph_frontend && pnpm format",
    "frontend:format:check": "cd ph_frontend && pnpm format:check",
    "dev": "concurrently \"pnpm backend:dev\" \"pnpm frontend:dev\"",
    "type-check": "pnpm backend:type-check && pnpm frontend:type-check",
    "lint": "pnpm backend:lint && pnpm frontend:lint",
    "lint:fix": "pnpm backend:lint:fix && pnpm frontend:lint:fix",
    "format": "pnpm backend:format && pnpm frontend:format",
    "format:check": "pnpm backend:format:check && pnpm frontend:format:check",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "pharmacy",
    "healthcare",
    "management",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7"
  }
}
