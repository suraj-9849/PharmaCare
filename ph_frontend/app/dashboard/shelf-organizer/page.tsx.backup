'use client';

import { useState, useEffect } from 'react';
import { apiClient } from '@/lib/api-client';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Progress } from '@/components/ui/progress';
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
} from '@/components/ui/dialog';
import { toast } from 'sonner';
import {
  Plus,
  Package,
  Archive,
  Search,
  X,
  GripVertical,
  ChevronDown,
  ChevronRight,
  AlertCircle,
  Trash2,
  ArrowLeftRight,
} from 'lucide-react';

// Types
interface Drug {
  id: string;
  brandName: string;
  genericName: string;
}

interface InventoryBatch {
  id: string;
  drugId: string;
  batchNumber: string;
  quantity: number;
  assignedQuantity: number;
  unassignedQuantity?: number;
  expiryDate: string;
  drug: Drug;
}

interface RackItem {
  id: string;
  shelfId: string;
  drugId: string;
  batchId: string;
  quantity: number;
  drug: Drug;
  batch: InventoryBatch;
}

interface Rack {
  id: string;
  cupboardId: string;
  name: string;
  capacity: number;
  currentOccupancy: number;
  order: number;
  shelfItems: RackItem[];
}

interface Shelf {
  id: string;
  name: string;
  description?: string;
  order: number;
  shelves: Rack[];
}

export default function ShelfOrganizerPage() {
  const [shelves, setShelves] = useState<Shelf[]>([]);
  const [unassignedInventory, setUnassignedInventory] = useState<InventoryBatch[]>([]);
  const [loading, setLoading] = useState(true);
  const [searchQuery, setSearchQuery] = useState('');
  const [selectedShelfId, setSelectedShelfId] = useState<string>('');

  // Dialog states
  const [showShelfDialog, setShowShelfDialog] = useState(false);
  const [showRackDialog, setShowRackDialog] = useState(false);
  const [showDeleteShelfDialog, setShowDeleteShelfDialog] = useState(false);
  const [showDeleteRackDialog, setShowDeleteRackDialog] = useState(false);
  const [shelfToDelete, setShelfToDelete] = useState<string>('');
  const [rackToDelete, setRackToDelete] = useState<string>('');
  const [shelfName, setShelfName] = useState('');
  const [shelfDescription, setShelfDescription] = useState('');
  const [rackName, setRackName] = useState('');
  const [rackCapacity, setRackCapacity] = useState('500');

  // Drag state
  const [draggedItem, setDraggedItem] = useState<{
    batch: InventoryBatch;
    quantity: number;
  } | null>(null);
  const [selectedQuantity, setSelectedQuantity] = useState<Record<string, number>>({});
  const [dragOverRackId, setDragOverRackId] = useState<string | null>(null);

  // Remove/Move dialog states
  const [showRemoveDialog, setShowRemoveDialog] = useState(false);
  const [showMoveDialog, setShowMoveDialog] = useState(false);
  const [selectedRackItem, setSelectedRackItem] = useState<RackItem | null>(null);
  const [removeQuantity, setRemoveQuantity] = useState('');
  const [targetRackId, setTargetRackId] = useState('');

  // Rack display states
  const [draggedRack, setDraggedRack] = useState<string | null>(null);

  useEffect(() => {
    loadData();
  }, []);

  const loadData = async () => {
    try {
      setLoading(true);
      const [shelvesRes, inventoryRes] = await Promise.all([
        apiClient.get('/shelf-management/cupboards'),
        apiClient.get('/shelf-management/unassigned'),
      ]);

      setShelves(shelvesRes.data || []);
      setUnassignedInventory(inventoryRes.data || []);

      // Select first shelf by default
      if (shelvesRes.data && shelvesRes.data.length > 0 && !selectedShelfId) {
        setSelectedShelfId(shelvesRes.data[0].id);
      }
    } catch (error) {
      console.error('Error loading data:', error);
      toast.error('Failed to load shelf data');
    } finally {
      setLoading(false);
    }
  };

  const createShelf = async () => {
    if (!shelfName.trim()) {
      toast.error('Please enter a shelf name');
      return;
    }

    try {
      await apiClient.post('/shelf-management/cupboards', {
        name: shelfName,
        description: shelfDescription,
      });

      toast.success('Shelf created successfully');
      setShowShelfDialog(false);
      setShelfName('');
      setShelfDescription('');
      loadData();
    } catch (error) {
      console.error('Error creating shelf:', error);
      toast.error('Failed to create shelf');
    }
  };

  const createRack = async () => {
    if (!rackName.trim() || !selectedShelfId) {
      toast.error('Please fill all fields');
      return;
    }

    const capacity = parseInt(rackCapacity);
    if (isNaN(capacity) || capacity <= 0) {
      toast.error('Please enter a valid capacity');
      return;
    }

    try {
      await apiClient.post('/shelf-management/shelves', {
        cupboardId: selectedShelfId,
        name: rackName,
        capacity,
      });

      toast.success('Rack created successfully');
      setShowRackDialog(false);
      setRackName('');
      setRackCapacity('500');
      loadData();
    } catch (error) {
      console.error('Error creating rack:', error);
      toast.error('Failed to create rack');
    }
  };

  const deleteCupboard = async () => {
    if (!cupboardToDelete) return;

    try {
      await apiClient.delete(`/shelf-management/cupboards/${cupboardToDelete}`);
      toast.success('Cupboard deleted successfully');
      setShowDeleteCupboardDialog(false);
      setCupboardToDelete('');

      // If deleted cupboard was selected, select another one
      if (selectedCupboardId === cupboardToDelete) {
        setSelectedCupboardId('');
      }
      loadData();
    } catch (error: any) {
      console.error('Error deleting cupboard:', error);
      toast.error(error.response?.data?.message || 'Failed to delete cupboard');
    }
  };

  const deleteShelf = async () => {
    if (!shelfToDelete) return;

    try {
      await apiClient.delete(`/shelf-management/shelves/${shelfToDelete}`);
      toast.success('Shelf deleted successfully');
      setShowDeleteShelfDialog(false);
      setShelfToDelete('');
      loadData();
    } catch (error: any) {
      console.error('Error deleting shelf:', error);
      toast.error(error.response?.data?.message || 'Failed to delete shelf');
    }
  };

  const handleDragStart = (e: React.DragEvent, batch: InventoryBatch) => {
    const qty = selectedQuantity[batch.id] || Math.min(50, batch.unassignedQuantity || 0);
    setDraggedItem({ batch, quantity: qty });

    // Create a custom drag image
    const dragElement = e.currentTarget.cloneNode(true) as HTMLElement;
    dragElement.style.position = 'absolute';
    dragElement.style.top = '-1000px';
    dragElement.style.width = (e.currentTarget as HTMLElement).offsetWidth + 'px';
    dragElement.style.opacity = '0.8';
    dragElement.style.transform = 'rotate(3deg)';
    dragElement.style.boxShadow = '0 20px 25px -5px rgba(0, 0, 0, 0.3)';
    document.body.appendChild(dragElement);
    e.dataTransfer.setDragImage(dragElement, 50, 50);
    setTimeout(() => document.body.removeChild(dragElement), 0);
  };

  const handleDragOver = (e: React.DragEvent, shelfId?: string) => {
    e.preventDefault();
    if (shelfId && draggedItem) {
      setDragOverShelfId(shelfId);
    }
  };

  const handleDragLeave = () => {
    setDragOverShelfId(null);
  };

  const handleDrop = async (e: React.DragEvent, shelfId: string) => {
    e.preventDefault();
    setDragOverShelfId(null);
    if (!draggedItem) return;

    try {
      await apiClient.post('/shelf-management/assign', {
        shelfId,
        batchId: draggedItem.batch.id,
        quantity: draggedItem.quantity,
      });

      toast.success(`Assigned ${draggedItem.quantity} units to shelf`);
      setDraggedItem(null);
      setSelectedQuantity({});
      loadData();
    } catch (error: any) {
      console.error('Error assigning to shelf:', error);
      toast.error(error.response?.data?.message || 'Failed to assign items');
    }
  };

  const handleDragEnd = () => {
    setDraggedItem(null);
    setDragOverShelfId(null);
  };

  const selectedCupboard = cupboards.find((c) => c.id === selectedCupboardId);

  const getCapacityColor = (percentage: number) => {
    if (percentage >= 90) return 'text-red-500';
    if (percentage >= 70) return 'text-yellow-500';
    return 'text-green-500';
  };

  const getShelfColor = (percentage: number) => {
    if (percentage >= 90) return 'bg-gradient-to-br from-red-100 via-red-50 to-orange-100 border-red-400';
    if (percentage >= 70) return 'bg-gradient-to-br from-yellow-100 via-amber-50 to-yellow-100 border-yellow-400';
    if (percentage >= 40) return 'bg-gradient-to-br from-blue-100 via-sky-50 to-cyan-100 border-blue-400';
    return 'bg-gradient-to-br from-green-100 via-emerald-50 to-teal-100 border-green-400';
  };

  const getDrugBoxColor = (index: number) => {
    const colors = [
      'bg-gradient-to-br from-purple-100 to-purple-200 border-purple-400',
      'bg-gradient-to-br from-pink-100 to-pink-200 border-pink-400',
      'bg-gradient-to-br from-blue-100 to-blue-200 border-blue-400',
      'bg-gradient-to-br from-green-100 to-green-200 border-green-400',
      'bg-gradient-to-br from-yellow-100 to-yellow-200 border-yellow-400',
      'bg-gradient-to-br from-indigo-100 to-indigo-200 border-indigo-400',
      'bg-gradient-to-br from-cyan-100 to-cyan-200 border-cyan-400',
      'bg-gradient-to-br from-rose-100 to-rose-200 border-rose-400',
    ];
    return colors[index % colors.length];
  };

  const handleRemoveItems = async () => {
    if (!selectedShelfItem) return;

    const qty = parseInt(removeQuantity);
    if (isNaN(qty) || qty <= 0 || qty > selectedShelfItem.quantity) {
      toast.error('Please enter a valid quantity');
      return;
    }

    try {
      await apiClient.post('/shelf-management/remove', {
        shelfItemId: selectedShelfItem.id,
        quantity: qty,
      });

      toast.success(`Removed ${qty} units from shelf`);
      setShowRemoveDialog(false);
      setSelectedShelfItem(null);
      setRemoveQuantity('');
      loadData();
    } catch (error: any) {
      console.error('Error removing items:', error);
      toast.error(error.response?.data?.message || 'Failed to remove items');
    }
  };

  const handleMoveItems = async () => {
    if (!selectedShelfItem || !targetShelfId) {
      toast.error('Please select a target shelf');
      return;
    }

    const qty = parseInt(removeQuantity);
    if (isNaN(qty) || qty <= 0 || qty > selectedShelfItem.quantity) {
      toast.error('Please enter a valid quantity');
      return;
    }

    try {
      // Find the source shelf from selectedShelfItem
      const sourceShelf = cupboards
        .flatMap((c) => c.shelves)
        .find((s) => s.id === selectedShelfItem.shelfId);

      await apiClient.post('/shelf-management/move', {
        fromShelfId: selectedShelfItem.shelfId,
        toShelfId: targetShelfId,
        batchId: selectedShelfItem.batchId,
        quantity: qty,
      });

      toast.success(`Moved ${qty} units to target shelf`);
      setShowMoveDialog(false);
      setSelectedShelfItem(null);
      setRemoveQuantity('');
      setTargetShelfId('');
      loadData();
    } catch (error: any) {
      console.error('Error moving items:', error);
      toast.error(error.response?.data?.message || 'Failed to move items');
    }
  };

  const handleShelfDragStart = (shelfId: string) => {
    setDraggedShelf(shelfId);
  };

  const handleShelfDragOver = (e: React.DragEvent, targetShelfId: string) => {
    e.preventDefault();
    if (draggedShelf && draggedShelf !== targetShelfId) {
      e.currentTarget.classList.add('border-blue-500', 'border-2');
    }
  };

  const handleShelfDragLeave = (e: React.DragEvent) => {
    e.currentTarget.classList.remove('border-blue-500', 'border-2');
  };

  const handleShelfDrop = async (e: React.DragEvent, targetShelfId: string) => {
    e.preventDefault();
    e.currentTarget.classList.remove('border-blue-500', 'border-2');

    if (!draggedShelf || draggedShelf === targetShelfId || !selectedCupboard) {
      return;
    }

    try {
      const draggedShelfObj = selectedCupboard.shelves.find((s) => s.id === draggedShelf);
      const targetShelfObj = selectedCupboard.shelves.find((s) => s.id === targetShelfId);

      if (!draggedShelfObj || !targetShelfObj) return;

      // Reorder by swapping orders
      await Promise.all([
        apiClient.put(`/shelf-management/shelves/${draggedShelf}`, {
          order: targetShelfObj.order,
        }),
        apiClient.put(`/shelf-management/shelves/${targetShelfId}`, {
          order: draggedShelfObj.order,
        }),
      ]);

      toast.success('Shelf reordered successfully');
      setDraggedShelf(null);
      loadData();
    } catch (error: any) {
      console.error('Error reordering shelves:', error);
      toast.error(error.response?.data?.message || 'Failed to reorder shelves');
    }
  };

  const filteredInventory = unassignedInventory.filter((batch) => {
    const query = searchQuery.toLowerCase();
    return (
      batch.drug.brandName.toLowerCase().includes(query) ||
      batch.drug.genericName.toLowerCase().includes(query) ||
      batch.batchNumber.toLowerCase().includes(query)
    );
  });

  if (loading) {
    return (
      <div className="flex items-center justify-center h-96">
        <div className="text-center">
          <Package className="h-12 w-12 animate-pulse mx-auto mb-4 text-gray-400" />
          <p className="text-gray-500">Loading shelf organizer...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="h-screen flex flex-col overflow-hidden">
      {/* Header */}
      <div className="flex-shrink-0 p-6 pb-4 border-b bg-white">
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-2xl font-bold">Shelf Organizer</h1>
            <p className="text-sm text-muted-foreground">
              Organize your inventory with drag and drop
            </p>
          </div>
        </div>
      </div>

      <div className="flex-1 grid grid-cols-2 gap-6 p-6 min-h-0 overflow-hidden">
        {/* LEFT SIDE - Unassigned Inventory */}
        <Card className="flex flex-col h-full overflow-hidden">
          <CardHeader className="pb-3 flex-shrink-0 border-b">
            <div className="flex items-center justify-between">
              <div>
                <CardTitle className="flex items-center gap-2 text-lg">
                  <Package className="h-5 w-5" />
                  Unassigned Inventory
                </CardTitle>
                <p className="text-xs text-muted-foreground mt-1">
                  {unassignedInventory.length} batches available
                </p>
              </div>
            </div>
            <div className="relative mt-3">
              <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-gray-400" />
              <Input
                placeholder="Search drugs..."
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                className="pl-10 h-9"
              />
            </div>
          </CardHeader>
          <CardContent className="flex-1 p-4 min-h-0 overflow-y-scroll">
            <div className="space-y-3 pr-2">
                {filteredInventory.map((batch) => {
                  const unassigned = batch.unassignedQuantity || 0;
                  const maxQty = Math.min(unassigned, 1000);
                  const currentQty = selectedQuantity[batch.id] || Math.min(50, unassigned);

                  return (
                    <div
                      key={batch.id}
                      draggable={unassigned > 0}
                      onDragStart={(e) => handleDragStart(e, batch)}
                      onDragEnd={handleDragEnd}
                      className={`
                        border-2 rounded-lg p-4 transition-all duration-200
                        ${
                          unassigned > 0
                            ? 'cursor-grab active:cursor-grabbing hover:shadow-xl hover:border-blue-500 hover:scale-[1.03] bg-gradient-to-br from-white to-blue-50'
                            : 'opacity-50 cursor-not-allowed bg-gray-50'
                        }
                        ${draggedItem?.batch.id === batch.id ? 'opacity-30 scale-90 rotate-2' : ''}
                      `}
                    >
                      <div className="flex items-start justify-between mb-2">
                        <div className="flex-1">
                          <h3 className="font-semibold text-sm">{batch.drug.brandName}</h3>
                          <p className="text-xs text-gray-500">{batch.drug.genericName}</p>
                        </div>
                        {unassigned > 0 && <GripVertical className="h-4 w-4 text-gray-400" />}
                      </div>

                      <div className="flex items-end justify-between">
                        <div className="text-xs text-gray-500">
                          Batch: {batch.batchNumber}
                        </div>
                        <Badge variant={unassigned > 0 ? 'default' : 'secondary'} className="text-xs">
                          {unassigned} available
                        </Badge>
                      </div>

                      {unassigned > 0 && (
                        <div className="mt-3 space-y-2">
                          <Label className="text-xs">Quantity to assign: {currentQty}</Label>
                          <input
                            type="range"
                            min="1"
                            max={maxQty}
                            value={currentQty}
                            onChange={(e) =>
                              setSelectedQuantity({
                                ...selectedQuantity,
                                [batch.id]: parseInt(e.target.value),
                              })
                            }
                            className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer"
                          />
                        </div>
                      )}
                    </div>
                  );
                })}

              {filteredInventory.length === 0 && (
                <div className="text-center py-12">
                  <Package className="h-12 w-12 mx-auto text-gray-300 mb-2" />
                  <p className="text-gray-500">No unassigned inventory</p>
                </div>
              )}
            </div>
          </CardContent>
        </Card>

        {/* RIGHT SIDE - Cupboards and Shelves */}
        <Card className="flex flex-col h-full overflow-hidden">
          <CardHeader className="pb-3 flex-shrink-0 border-b">
            <div className="flex items-center justify-between mb-3">
              <CardTitle className="flex items-center gap-2 text-lg">
                <Archive className="h-5 w-5" />
                Storage Organization
              </CardTitle>
              <Button size="sm" onClick={() => setShowCupboardDialog(true)}>
                <Plus className="h-4 w-4 mr-1" />
                New Cupboard
              </Button>
            </div>

            {/* Cupboard Selector */}
            {cupboards.length > 0 && (
              <div className="flex items-center gap-2">
                <select
                  className="flex-1 border rounded-md p-2 text-sm h-9"
                  value={selectedCupboardId}
                  onChange={(e) => setSelectedCupboardId(e.target.value)}
                >
                  {cupboards.map((c) => (
                    <option key={c.id} value={c.id}>
                      {c.name} ({c.shelves.length} shelves)
                    </option>
                  ))}
                </select>
                {selectedCupboard && (
                  <Button
                    size="sm"
                    variant="ghost"
                    className="text-red-500 hover:text-red-700 h-9 w-9 p-0"
                    onClick={() => {
                      setCupboardToDelete(selectedCupboard.id);
                      setShowDeleteCupboardDialog(true);
                    }}
                  >
                    <Trash2 className="h-4 w-4" />
                  </Button>
                )}
              </div>
            )}
          </CardHeader>
          <CardContent className="flex-1 p-4 min-h-0 overflow-y-scroll">
              {selectedCupboard ? (
                <div className="space-y-4">
                  {/* Cupboard Header */}
                  <div className="bg-gradient-to-br from-indigo-100 via-purple-50 to-pink-100 rounded-xl p-4 sticky top-0 z-10 border-2 border-purple-300 shadow-lg backdrop-blur-sm">
                    <div className="flex items-center justify-between">
                      <div className="flex-1">
                        <h3 className="font-bold text-lg text-gray-900">{selectedCupboard.name}</h3>
                        {selectedCupboard.description && (
                          <p className="text-xs text-gray-700 font-medium mt-1">{selectedCupboard.description}</p>
                        )}
                      </div>
                      <Button size="sm" onClick={() => setShowShelfDialog(true)} className="h-9 bg-purple-600 hover:bg-purple-700 shadow-md">
                        <Plus className="h-4 w-4 mr-1" />
                        Add Shelf
                      </Button>
                    </div>
                  </div>

                  {/* Shelves Display - Stacked like real shelves */}
                  <div className="space-y-4">
                    {selectedCupboard.shelves
                      .sort((a, b) => a.order - b.order)
                      .map((shelf) => {
                        const percentage = (shelf.currentOccupancy / shelf.capacity) * 100;
                        const isBeingDraggedOver = dragOverShelfId === shelf.id;
                        return (
                          <div
                            key={shelf.id}
                            className={`
                              relative transition-all duration-300
                              ${draggedShelf === shelf.id ? 'opacity-50' : ''}
                            `}
                          >
                            {/* Shelf Header */}
                            <div
                              className="flex items-center justify-between mb-2 px-2"
                              draggable
                              onDragStart={() => handleShelfDragStart(shelf.id)}
                            >
                              <div className="flex items-center gap-2">
                                <GripVertical className="h-4 w-4 text-gray-400 cursor-grab active:cursor-grabbing" />
                                <h4 className="font-semibold text-sm">{shelf.name}</h4>
                                <Badge
                                  variant="outline"
                                  className={`text-xs ${getCapacityColor(percentage)}`}
                                >
                                  {percentage.toFixed(0)}%
                                </Badge>
                              </div>
                              <div className="flex items-center gap-2">
                                <span className="text-xs text-gray-500">
                                  {shelf.currentOccupancy}/{shelf.capacity}
                                </span>
                                <Button
                                  size="sm"
                                  variant="ghost"
                                  className="h-6 w-6 p-0 text-red-500 hover:text-red-700"
                                  onClick={(e) => {
                                    e.stopPropagation();
                                    setShelfToDelete(shelf.id);
                                    setShowDeleteShelfDialog(true);
                                  }}
                                >
                                  <Trash2 className="h-3 w-3" />
                                </Button>
                              </div>
                            </div>

                            {/* Actual Shelf with 3D effect */}
                            <div
                              onDragOver={(e) => {
                                handleDragOver(e, shelf.id);
                                handleShelfDragOver(e, shelf.id);
                              }}
                              onDragLeave={() => {
                                handleDragLeave();
                                handleShelfDragLeave(event as any);
                              }}
                              onDrop={(e) => {
                                handleDrop(e, shelf.id);
                                handleShelfDrop(e, shelf.id);
                              }}
                              className={`
                                relative rounded-xl border-3 overflow-hidden
                                transition-all duration-300 shadow-lg
                                ${getShelfColor(percentage)}
                                ${isBeingDraggedOver
                                  ? 'border-blue-500 shadow-2xl scale-[1.03] ring-4 ring-blue-300 animate-pulse'
                                  : 'hover:shadow-xl hover:scale-[1.01]'
                                }
                              `}
                            >
                              {/* Shelf top border - enhanced wood effect */}
                              <div className="h-3 bg-gradient-to-b from-amber-900 via-amber-800 to-amber-700 border-b-2 border-amber-950 shadow-inner relative">
                                <div className="absolute inset-0 bg-gradient-to-r from-transparent via-amber-700/50 to-transparent"></div>
                              </div>

                              {/* Shelf content area */}
                              <div className="p-4 min-h-[120px]">
                                {shelf.shelfItems.length > 0 ? (
                                  <div className="flex flex-wrap gap-3">
                                    {shelf.shelfItems.map((item, index) => (
                                      <div
                                        key={item.id}
                                        className="group relative"
                                      >
                                        {/* Drug box on shelf */}
                                        <div className={`
                                          border-3 rounded-lg shadow-lg
                                          p-3 min-w-[140px] max-w-[160px]
                                          hover:shadow-2xl hover:scale-105 transition-all duration-200
                                          cursor-pointer relative overflow-hidden
                                          ${getDrugBoxColor(index)}
                                        `}>
                                          {/* Shine effect */}
                                          <div className="absolute inset-0 bg-gradient-to-tr from-transparent via-white/20 to-transparent pointer-events-none"></div>

                                          <div className="flex items-start justify-between mb-1 relative z-10">
                                            <div className="flex-1 min-w-0">
                                              <h5 className="font-bold text-xs truncate text-gray-900">
                                                {item.drug.brandName}
                                              </h5>
                                              <p className="text-[10px] text-gray-700 truncate font-medium">
                                                {item.drug.genericName}
                                              </p>
                                            </div>
                                          </div>

                                          <div className="mt-2 pt-2 border-t-2 border-gray-300/50 relative z-10">
                                            <div className="flex items-center justify-between">
                                              <span className="text-[10px] text-gray-700 font-semibold">
                                                {item.batch.batchNumber}
                                              </span>
                                              <Badge variant="default" className="text-[10px] h-5 px-2 font-bold shadow-sm">
                                                {item.quantity}
                                              </Badge>
                                            </div>
                                          </div>

                                          {/* Action buttons */}
                                          <div className="absolute top-1 right-1 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <Button
                                              size="sm"
                                              variant="ghost"
                                              className="h-5 w-5 p-0 bg-white shadow-sm hover:bg-blue-50"
                                              onClick={(e) => {
                                                e.stopPropagation();
                                                setSelectedShelfItem(item);
                                                setRemoveQuantity(item.quantity.toString());
                                                setShowMoveDialog(true);
                                              }}
                                            >
                                              <ArrowLeftRight className="h-3 w-3 text-blue-600" />
                                            </Button>
                                            <Button
                                              size="sm"
                                              variant="ghost"
                                              className="h-5 w-5 p-0 bg-white shadow-sm hover:bg-red-50"
                                              onClick={(e) => {
                                                e.stopPropagation();
                                                setSelectedShelfItem(item);
                                                setRemoveQuantity(item.quantity.toString());
                                                setShowRemoveDialog(true);
                                              }}
                                            >
                                              <Trash2 className="h-3 w-3 text-red-600" />
                                            </Button>
                                          </div>
                                        </div>

                                        {/* Enhanced shadow under box */}
                                        <div className="h-2 bg-black/10 rounded-full blur-md mt-1 mx-3"></div>
                                      </div>
                                    ))}
                                  </div>
                                ) : (
                                  <div className="flex items-center justify-center h-24">
                                    <div className={`text-center p-4 rounded-lg ${isBeingDraggedOver ? 'bg-blue-100/50 border-2 border-dashed border-blue-400' : 'bg-gray-100/50'}`}>
                                      <p className="text-sm font-bold text-gray-600">
                                        {isBeingDraggedOver ? '📦 Drop here!' : '✨ Empty shelf'}
                                      </p>
                                    </div>
                                  </div>
                                )}
                              </div>

                              {/* Shelf bottom border - enhanced wood effect */}
                              <div className="h-4 bg-gradient-to-t from-amber-900 via-amber-800 to-amber-700 border-t-2 border-amber-950 shadow-lg relative">
                                <div className="absolute inset-0 bg-gradient-to-r from-transparent via-amber-700/50 to-transparent"></div>
                                <div className="absolute bottom-0 left-0 right-0 h-1 bg-amber-950/30"></div>
                              </div>

                              {/* Progress bar at bottom */}
                              <div className="px-4 pb-2">
                                <Progress value={percentage} className="h-1.5" />
                              </div>
                            </div>
                          </div>
                        );
                      })}

                        {selectedCupboard.shelves.length === 0 && (
                          <div className="text-center py-8">
                            <Package className="h-10 w-10 mx-auto text-gray-300 mb-2" />
                            <p className="text-sm text-gray-400 mb-3">No shelves in this cupboard</p>
                            <Button size="sm" onClick={() => setShowShelfDialog(true)}>
                              <Plus className="h-4 w-4 mr-1" />
                              Add First Shelf
                            </Button>
                          </div>
                        )}
                      </div>
                    </div>
                  ) : (
                    <div className="text-center py-12">
                      <Archive className="h-12 w-12 mx-auto text-gray-300 mb-2" />
                      <p className="text-gray-500 mb-3">No cupboards created yet</p>
                      <Button onClick={() => setShowCupboardDialog(true)}>
                        <Plus className="h-4 w-4 mr-2" />
                        Create Your First Cupboard
                      </Button>
                    </div>
                  )}
          </CardContent>
        </Card>
      </div>

      {/* Create Cupboard Dialog */}
      <Dialog open={showCupboardDialog} onOpenChange={setShowCupboardDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Create New Cupboard</DialogTitle>
            <DialogDescription>Add a new cupboard to organize your inventory</DialogDescription>
          </DialogHeader>
          <div className="space-y-4 py-4">
            <div>
              <Label>Cupboard Name</Label>
              <Input
                placeholder="e.g., Cupboard A, Refrigerated Storage"
                value={cupboardName}
                onChange={(e) => setCupboardName(e.target.value)}
              />
            </div>
            <div>
              <Label>Description (Optional)</Label>
              <Input
                placeholder="e.g., For temperature-sensitive items"
                value={cupboardDescription}
                onChange={(e) => setCupboardDescription(e.target.value)}
              />
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowCupboardDialog(false)}>
              Cancel
            </Button>
            <Button onClick={createCupboard}>Create Cupboard</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Create Shelf Dialog */}
      <Dialog open={showShelfDialog} onOpenChange={setShowShelfDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Create New Shelf</DialogTitle>
            <DialogDescription>
              Add a new shelf to {selectedCupboard?.name}
            </DialogDescription>
          </DialogHeader>
          <div className="space-y-4 py-4">
            <div>
              <Label>Shelf Name</Label>
              <Input
                placeholder="e.g., Shelf 1, Top Shelf"
                value={shelfName}
                onChange={(e) => setShelfName(e.target.value)}
              />
            </div>
            <div>
              <Label>Capacity (units)</Label>
              <Input
                type="number"
                placeholder="500"
                value={shelfCapacity}
                onChange={(e) => setShelfCapacity(e.target.value)}
              />
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowShelfDialog(false)}>
              Cancel
            </Button>
            <Button onClick={createShelf}>Create Shelf</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Delete Cupboard Confirmation */}
      <Dialog open={showDeleteCupboardDialog} onOpenChange={setShowDeleteCupboardDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Delete Cupboard?</DialogTitle>
            <DialogDescription>
              This will delete the cupboard and all its shelves. Items will be returned to unassigned inventory.
            </DialogDescription>
          </DialogHeader>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowDeleteCupboardDialog(false)}>
              Cancel
            </Button>
            <Button variant="destructive" onClick={deleteCupboard}>
              <Trash2 className="h-4 w-4 mr-2" />
              Delete Cupboard
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Delete Shelf Confirmation */}
      <Dialog open={showDeleteShelfDialog} onOpenChange={setShowDeleteShelfDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Delete Shelf?</DialogTitle>
            <DialogDescription>
              This will delete the shelf. Items will be returned to unassigned inventory.
            </DialogDescription>
          </DialogHeader>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowDeleteShelfDialog(false)}>
              Cancel
            </Button>
            <Button variant="destructive" onClick={deleteShelf}>
              <Trash2 className="h-4 w-4 mr-2" />
              Delete Shelf
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Remove Items Dialog */}
      <Dialog open={showRemoveDialog} onOpenChange={setShowRemoveDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Remove Items from Shelf</DialogTitle>
            <DialogDescription>
              Remove items and return them to unassigned inventory
            </DialogDescription>
          </DialogHeader>
          {selectedShelfItem && (
            <div className="space-y-4 py-4">
              <div className="bg-gray-50 p-3 rounded-md">
                <p className="text-sm font-medium">{selectedShelfItem.drug.brandName}</p>
                <p className="text-xs text-gray-500">{selectedShelfItem.drug.genericName}</p>
                <p className="text-xs text-gray-500 mt-1">
                  Batch: {selectedShelfItem.batch.batchNumber}
                </p>
                <p className="text-xs text-gray-500">
                  Available on shelf: {selectedShelfItem.quantity} units
                </p>
              </div>
              <div>
                <Label>Quantity to Remove</Label>
                <Input
                  type="number"
                  placeholder="Enter quantity"
                  value={removeQuantity}
                  onChange={(e) => setRemoveQuantity(e.target.value)}
                  max={selectedShelfItem.quantity}
                  min={1}
                />
              </div>
            </div>
          )}
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowRemoveDialog(false)}>
              Cancel
            </Button>
            <Button variant="destructive" onClick={handleRemoveItems}>
              <Trash2 className="h-4 w-4 mr-2" />
              Remove
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Move Items Dialog */}
      <Dialog open={showMoveDialog} onOpenChange={setShowMoveDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Move Items to Another Shelf</DialogTitle>
            <DialogDescription>Move items from one shelf to another</DialogDescription>
          </DialogHeader>
          {selectedShelfItem && (
            <div className="space-y-4 py-4">
              <div className="bg-gray-50 p-3 rounded-md">
                <p className="text-sm font-medium">{selectedShelfItem.drug.brandName}</p>
                <p className="text-xs text-gray-500">{selectedShelfItem.drug.genericName}</p>
                <p className="text-xs text-gray-500 mt-1">
                  Batch: {selectedShelfItem.batch.batchNumber}
                </p>
                <p className="text-xs text-gray-500">
                  Available: {selectedShelfItem.quantity} units
                </p>
              </div>
              <div>
                <Label>Quantity to Move</Label>
                <Input
                  type="number"
                  placeholder="Enter quantity"
                  value={removeQuantity}
                  onChange={(e) => setRemoveQuantity(e.target.value)}
                  max={selectedShelfItem.quantity}
                  min={1}
                />
              </div>
              <div>
                <Label>Target Shelf</Label>
                <select
                  className="w-full border rounded-md p-2"
                  value={targetShelfId}
                  onChange={(e) => setTargetShelfId(e.target.value)}
                >
                  <option value="">Select target shelf</option>
                  {cupboards.flatMap((cupboard) =>
                    cupboard.shelves
                      .filter((shelf) => shelf.id !== selectedShelfItem.shelfId)
                      .map((shelf) => (
                        <option key={shelf.id} value={shelf.id}>
                          {cupboard.name} → {shelf.name} ({shelf.currentOccupancy}/{shelf.capacity} units)
                        </option>
                      ))
                  )}
                </select>
              </div>
            </div>
          )}
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowMoveDialog(false)}>
              Cancel
            </Button>
            <Button onClick={handleMoveItems}>
              <ArrowLeftRight className="h-4 w-4 mr-2" />
              Move Items
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}
