# Environment Configuration
# Database
DB_NAME=pharmacy
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Backend
NODE_ENV=production
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Razorpay (Update with your actual keys)
RAZORPAY_KEY_ID=rzp_live_placeholder_key
RAZORPAY_KEY_SECRET=razorpay_placeholder_secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_placeholder_key
